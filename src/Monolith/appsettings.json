{
  "Service": {
    "Name": "Monolith",
    "Description": "Single-process baseline API for gateway evaluation.",
    "Capabilities": [
      "Search",
      "Mail",
      "Deduplication",
      "Users"
    ]
  },
  "Architecture": {
    "Mode": "ModeA",
    "Flow": "Monolith -> Services"
  },
  "DownstreamServices": {
    "SearchService": {
      "BaseAddress": "http://localhost:5113",
      "PathPrefix": "/api/search",
      "InfoPath": "info"
    },
    "MailService": {
      "BaseAddress": "http://localhost:5288",
      "PathPrefix": "/api/mail",
      "InfoPath": "info"
    },
    "DeduplicationService": {
      "BaseAddress": "http://localhost:5114",
      "PathPrefix": "/api/deduplication",
      "InfoPath": "info"
    },
    "UserService": {
      "BaseAddress": "http://localhost:5115",
      "PathPrefix": "/api/users",
      "InfoPath": "info"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
