{
  "Service": {
    "Name": "Gateway.Yarp",
    "Description": "YARP API Gateway for the gateway playground.",
    "Capabilities": [
      "YARP reverse proxy",
      "Configuration-based routing",
      "Swagger aggregation",
      "Health checks",
      "Correlation ID propagation"
    ]
  },
  "Swagger": {
    "Endpoints": [
      {
        "Name": "SearchService",
        "Url": "/service-docs/search/swagger.json"
      },
      {
        "Name": "MailService",
        "Url": "/service-docs/mail/swagger.json"
      },
      {
        "Name": "DeduplicationService",
        "Url": "/service-docs/deduplication/swagger.json"
      },
      {
        "Name": "UserService",
        "Url": "/service-docs/users/swagger.json"
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "search-api": {
        "ClusterId": "search-service",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      },
      "mail-api": {
        "ClusterId": "mail-service",
        "Match": {
          "Path": "/api/mail/{**catch-all}"
        }
      },
      "deduplication-api": {
        "ClusterId": "deduplication-service",
        "Match": {
          "Path": "/api/deduplication/{**catch-all}"
        }
      },
      "users-api": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "search-swagger": {
        "ClusterId": "search-service",
        "Match": {
          "Path": "/service-docs/search/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "mail-swagger": {
        "ClusterId": "mail-service",
        "Match": {
          "Path": "/service-docs/mail/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "deduplication-swagger": {
        "ClusterId": "deduplication-service",
        "Match": {
          "Path": "/service-docs/deduplication/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      },
      "users-swagger": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/service-docs/users/swagger.json"
        },
        "Transforms": [
          {
            "PathSet": "/swagger/v1/swagger.json"
          }
        ]
      }
    },
    "Clusters": {
      "search-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "search-service-http": {
            "Address": "http://localhost:5113/"
          }
        }
      },
      "mail-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "mail-service-http": {
            "Address": "http://localhost:5288/"
          }
        }
      },
      "deduplication-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "deduplication-service-http": {
            "Address": "http://localhost:5114/"
          }
        }
      },
      "user-service": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "user-service-http": {
            "Address": "http://localhost:5115/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}
