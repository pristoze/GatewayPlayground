{
  "Service": {
    "Name": "Gateway.Ocelot",
    "Description": "Ocelot API Gateway for the gateway playground.",
    "Capabilities": [
      "Ocelot reverse proxy",
      "Configuration-based routing",
      "Swagger aggregation",
      "Health checks",
      "Correlation ID propagation"
    ]
  },
  "Authentication": {
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/gateway-playground",
      "Audience": "gateway-playground-api",
      "RequireHttpsMetadata": false,
      "ValidateAudience": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Ocelot": "Information"
    }
  },
  "AllowedHosts": "*"
}
