{
  "Service": {
    "Name": "Gateway.Ocelot",
    "Description": "Ocelot API Gateway for the gateway playground.",
    "Capabilities": [
      "Ocelot reverse proxy",
      "Configuration-based routing",
      "Swagger aggregation",
      "Health checks",
      "Correlation ID propagation"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Ocelot": "Information"
    }
  },
  "AllowedHosts": "*"
}
