{
  "Service": {
    "Name": "MailService",
    "Description": "Mail API used by the gateway playground.",
    "Capabilities": [
      "Mail template listing",
      "Mail preview generation"
    ]
  },
  "Authentication": {
    "Keycloak": {
      "Authority": "http://localhost:8080/realms/gateway-playground",
      "Audience": "gateway-playground-api",
      "RequireHttpsMetadata": false,
      "ValidateAudience": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
